---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre mí" description="Matías Z. — Agentic AI, GCP y arquitectura de sistemas.">
  <div class="page-wrapper">
    <div style="padding: 4rem 0; max-width: 640px;">
      <h1 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 1.5rem;">
        Matías Z.
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.75; margin-bottom: 1rem;">
        Diseño y construyo sistemas de IA agéntica sobre GCP — desde la arquitectura hasta producción.
      </p>
      <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.75; margin-bottom: 2rem;">
        Escribo sobre lo que aprendo en el proceso: arquitectura de agentes, LLMs en producción,
        infraestructura cloud, y las decisiones de diseño que no aparecen en los papers.
      </p>
      <a
        href="https://linkedin.com/in/mzabaljauregui"
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-accent); color: white; font-weight: 600; font-size: 0.9375rem; padding: 0.625rem 1.25rem; border-radius: var(--radius-md); text-decoration: none; transition: background .2s;"
      >
        Conectar en LinkedIn
      </a>
    </div>
  </div>
</Layout>
